# 微信Webhook配置
# 将此文件复制为 .env 并填入你的webhook URL

# 企业微信机器人webhook地址
# 获取方式：企业微信 -> 群聊 -> 群机器人 -> 添加机器人 -> 复制Webhook地址
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# 示例：
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=693a91f6-7xxx-4xxx-9xxx-xxxxxxxxxx
